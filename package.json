{
  "name": "review-simple",
  "version": "1.4.0",
  "description": "Obsidian periodic review plugin",
  "license": "MIT",
  "main": "main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "check": "npm test && npm run build && npm run lint:obsidian",
    "lint:obsidian": "eslint src/ tests/",
    "test": "tsc --noEmit --skipLibCheck --project tsconfig.test.json && vitest run"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
